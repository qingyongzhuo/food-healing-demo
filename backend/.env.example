# ===== AI 平台 API Key =====
DASHSCOPE_API_KEY=your_dashscope_key_here
BAILIAN_API_KEY=your_bailian_key_here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== AI 模型名 =====
QWEN_VL_MODEL=qwen-vl-max
QWEN_VL_MODEL_FALLBACK=qwen-vl-plus
QWEN_PLUS_MODEL=qwen3.7-plus
QWEN_MAX_MODEL=qwen3.7-max
QWEN_FLASH_MODEL=qwen3.7-flash

# ===== 数据库 =====
MYSQL_DSN=mysql+aiomysql://root:password@127.0.0.1:3306/food_healing?charset=utf8mb4
PG_DSN=postgresql+asyncpg://postgres:password@127.0.0.1:5432/food_healing
REDIS_URL=redis://:password@127.0.0.1:6379/0

# ===== MQ =====
RABBITMQ_URL=amqp://guest:password@127.0.0.1:5672/

# ===== 对象存储 =====
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=food-healing-images
OSS_ACCESS_KEY_ID=your_ak
OSS_ACCESS_KEY_SECRET=your_sk

# ===== Nacos =====
NACOS_SERVER=127.0.0.1:8848
NACOS_NAMESPACE=dev
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ===== 应用 =====
ENV=dev
CORS_ORIGINS=["*"]
LOG_LEVEL=INFO
APP_NAME=食愈校园
APP_VERSION=0.1.0
REDIS_KEY_PREFIX=food_healing:
